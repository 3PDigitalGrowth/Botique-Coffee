# Resend (https://resend.com) — required for form emails in production
RESEND_API_KEY=re_your_key_here

# From address must use a domain verified in Resend (e.g. coffee.websitesubmission.com.au)
RESEND_FROM="Boutique Coffee <enquiry@coffee.websitesubmission.com.au>"

# Public site URL (used in admin notification “open page” links). Optional if correct default matches production.
NEXT_PUBLIC_SITE_URL=https://boutiquecoffee.com.au

# Optional: Reply-To on the automatic confirmation email to the visitor (so “Reply” goes to Chris)
CONTACT_REPLY_TO=chris@boutiquecoffee.com.au
