# Resend (https://resend.com) — required for form emails in production
RESEND_API_KEY=re_your_key_here

# From address must use a domain verified in Resend (e.g. coffee.websitesubmission.com.au)
RESEND_FROM="Boutique Coffee <noreply@coffee.websitesubmission.com.au>"

# All form submissions go to these addresses (comma-separated)
CONTACT_RECIPIENTS=alex@3pdigital.com.au,chris@boutiquecoffee.com.au
